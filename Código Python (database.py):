Validación de Ediciones del HOLE_ID (Límite de 4 veces):
Antes de permitir que el perforista cambie el HOLE_ID, haz esto en Python:

def actualizar_hole_id(db, pozo, nuevo_hole_id, usuario):
    if pozo.perforacion_finalizada:
        raise PermissionError("El pozo ya está finalizado. Solo el Geólogo Admin puede modificarlo.")
    
    if usuario.rol == 'perforista' and pozo.ediciones_hole_id_restantes <= 0:
        raise PermissionError("Ha alcanzado el límite de 4 ediciones. Contacte al Geólogo.")
    
    # Registrar en auditoría
    aud = AuditoriaPozo(id_pozo=pozo.id_pozo, id_usuario=usuario.id_usuario, 
                        campo_modificado="hole_id", valor_anterior=pozo.hole_id, valor_nuevo=nuevo_hole_id)
    db.add(aud)
    
    # Actualizar pozo
    pozo.hole_id = nuevo_hole_id
    if usuario.rol == 'perforista':
        pozo.ediciones_hole_id_restantes -= 1
        
    db.commit()

